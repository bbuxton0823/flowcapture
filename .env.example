# FlowCapture credentials
# ========================
# This is documentation only. Chrome extensions can't read .env at runtime —
# the values below are what you paste into the extension's Settings page
# (chrome-extension://<id>/src/pages/settings/settings.html) after install.
#
# Everything here is OPTIONAL. The extension works as a fully local SOP
# capture + PDF export tool without any of these credentials. Each item
# unlocks a specific integration:
#   - ElevenLabs        → AI narration in generated videos
#   - YouTube           → "Publish to YouTube" button
#   - Vimeo             → "Publish to Vimeo" button
#   - Google OAuth      → Google Drive team sync (also requires manifest edit)

# ─── ElevenLabs (AI narration) ───────────────────────────────────────
# Get at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Default voice ID (loaded from Settings → "Load voices")
ELEVENLABS_DEFAULT_VOICE_ID=
# Model — eleven_multilingual_v2 is the default and works for most cases
ELEVENLABS_DEFAULT_MODEL=eleven_multilingual_v2

# ─── YouTube (Publish to YouTube) ────────────────────────────────────
# 1. Google Cloud Console → New Project
# 2. Enable "YouTube Data API v3"
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URIs: paste the URI shown in Settings → YouTube
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# ─── Vimeo (Publish to Vimeo) ────────────────────────────────────────
# https://developer.vimeo.com/apps → Create app → "Personal Access Token"
# Required scopes: upload, edit, delete, video_files, public, private
VIMEO_ACCESS_TOKEN=

# ─── Google Drive sync (team SOP storage) ────────────────────────────
# Requires an OAuth 2.0 Client ID of type "Chrome Extension" in the same
# Google Cloud project. Paste into manifest.json under "oauth2.client_id"
# AND reload the extension. See README "Google Drive setup".
GOOGLE_OAUTH_CLIENT_ID=

# ─── Default publish settings ────────────────────────────────────────
# 'unlisted' | 'private' | 'public'   — applied to YouTube and Vimeo uploads
DEFAULT_PUBLISH_PRIVACY=unlisted
DEFAULT_AUTO_CAPTIONS=true
